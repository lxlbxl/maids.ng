# Application
APP_NAME="Maids.ng"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_SECRET=your-secret-key-here-change-in-production

# CORS - Comma-separated list of allowed origins (supports *.domain.com wildcards)
# For production: https://maids.ng,https://admin.maids.ng,https://app.maids.ng
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Database
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=maids_ng
DB_USERNAME=root
DB_PASSWORD=
DB_SQLITE_PATH=../storage/database.sqlite

# Session
SESSION_NAME=maids_session
SESSION_LIFETIME=7200

# JWT Configuration (for mobile app support)
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxx

# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx

# N8N Webhooks
N8N_BASE_URL=https://n8n.ai20.city/webhook
N8N_WEBHOOK_SECRET=your-webhook-secret

# QoreID NIN Verification (NIN Premium)
# Get your token from https://dashboard.qoreid.com
QOREID_TOKEN=your-qoreid-token-here

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,pdf

# Service Fees
SERVICE_FEE_AMOUNT=10000
SERVICE_FEE_CURRENCY=NGN

# SendGrid Email (get API key from https://sendgrid.com)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@maids.ng
EMAIL_FROM_NAME=Maids.ng

# Termii SMS (get API key from https://termii.com)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=Maids.ng
TERMII_CHANNEL=generic
