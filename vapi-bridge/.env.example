# Server Configuration
PORT=3000

# Maids.ng API Configuration
MAIDS_NG_API_URL=https://staging-api.maids.ng/v1
MAIDS_NG_API_KEY=your_maids_ng_api_key_here

# Vapi Webhook Security (optional)
# Set this to validate incoming Vapi webhook signatures
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# Logging
LOG_LEVEL=info
