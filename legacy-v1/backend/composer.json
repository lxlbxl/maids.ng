{
    "name": "maids-ng/backend",
    "description": "Maids.ng PHP Backend API and Admin Panel",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "intervention/image": "^3.4",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "migrate": "php bin/migrate.php",
        "seed": "php bin/seed.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
